{
  "version": 2,
  "rewrites": [
    {
      "source": "/pixel/:id",
      "destination": "/api/pixel/:id"
    }
  ],
  "headers": [
    {
      "source": "/api/pixel/:id",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300"
        }
      ]
    }
  ]
}